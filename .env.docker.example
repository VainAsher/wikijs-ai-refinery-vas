# Copy to .env for docker compose:  cp .env.docker.example .env
# See docs/deployment.md for the full guide.

# --- Image (used by CI/registry; safe to leave default for local builds) -------
# REFINERY_IMAGE=ghcr.io/vainasher/wikijs-ai-refinery-vas:latest

# --- Host port for direct LAN access (the Cloudflare tunnel doesn't need it) ----
REFINERY_PORT=8000

# --- Ollama on your LAN / homelab ----------------------------------------------
# Point at your LAN Ollama's /api/generate endpoint:
OLLAMA_URL=http://192.168.0.50:11434/api/generate
OLLAMA_MODEL=mistral:latest
# Optional extra hosts the in-app "Auto-detect Ollama" should probe (comma list):
# OLLAMA_LAN_HOSTS=192.168.0.50:11434,ollama.lan
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=4096

# --- Secrets at rest ------------------------------------------------------------
# Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
REFINERY_SECRET_KEY=

# --- App-level Basic Auth (recommended when exposed via the tunnel) -------------
REFINERY_BASIC_AUTH_USER=
REFINERY_BASIC_AUTH_PASS=

# --- Cloudflare tunnel (only needed for: docker compose --profile tunnel up) ----
# From the Cloudflare Zero Trust dashboard (Networks -> Tunnels -> your tunnel token):
CLOUDFLARE_TUNNEL_TOKEN=
